---
// FAQ block using homepage card styling: dl cards, optional HTML answers, footer links.
export interface FaqFooterLink {
  label: string;
  href: string;
}

export interface FaqItem {
  question: string;
  answer: string;
  answerHtml?: boolean;
  footerLinks?: FaqFooterLink[];
}

interface Props {
  items: FaqItem[];
  heading?: string;
  headingId?: string;
}

const {
  items,
  heading = 'Frequently Asked Questions',
  headingId = 'faq-heading',
} = Astro.props;

const faqLinkClass =
  'text-xs font-medium text-purple transition-colors hover:text-coral sm:text-[0.8125rem]';
---

<section class="space-y-6 border-t border-charcoal/10 pt-10" aria-labelledby={headingId}>
  <h2 id={headingId} class="font-display text-2xl font-semibold sm:text-3xl">{heading}</h2>
  <dl class="space-y-6">
    {
      items.map((faq) => (
        <div class="rounded-lg border border-charcoal/10 bg-white/70 p-4 sm:p-5">
          <dt>
            <h3 class="font-display text-base font-semibold text-charcoal sm:text-lg">{faq.question}</h3>
          </dt>
          <dd class="mt-2 text-muted">
            {faq.answerHtml ? <div set:html={faq.answer} /> : <p>{faq.answer}</p>}
            {faq.footerLinks && faq.footerLinks.length > 0 && (
              <ul class="mt-3 flex flex-col gap-1 border-t border-charcoal/10 pt-3 sm:gap-1.5">
                {faq.footerLinks.map((link) => (
                  <li>
                    <a href={link.href} class={faqLinkClass}>
                      {link.label} →
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </dd>
        </div>
      ))
    }
  </dl>
</section>
