---
const phone = '321-557-6959';
const phoneHref = 'tel:+13215576959';
const email = 'iwctpaintingplus@gmail.com';
const emailHref = 'mailto:iwctpaintingplus@gmail.com';

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Services', href: '/services' },
  { label: 'Homeowner Guide', href: '/homeowner-guide' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];
---

<footer class="mt-auto border-t border-charcoal/10 bg-charcoal/[0.02]">
  <div class="watercolor-divider" aria-hidden="true"></div>

  <div class="page-container py-12 lg:py-16">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-3 lg:gap-12">
      <div class="lg:col-span-1">
        <p class="font-display text-lg font-semibold text-charcoal">If Walls Could Talk LLC</p>
        <p class="mt-3 text-sm leading-relaxed text-muted">
          Owner-operated painting in Brevard County. Built on clear standards, honest communication, and
          crews who do the work the right way.
        </p>
        <p class="mt-5">
          <a
            href="/contact"
            class="inline-block text-sm font-semibold text-purple transition-colors hover:text-coral"
          >
            Send a message →
          </a>
          <span class="mt-1 block text-xs text-muted">Preferred way to reach us about your project</span>
        </p>
        <ul class="mt-4 space-y-2 text-sm">
          <li>
            <a href={phoneHref} class="font-medium text-purple transition-colors hover:text-coral">
              {phone}
            </a>
          </li>
          <li>
            <a href={emailHref} class="text-purple transition-colors hover:text-coral">
              {email}
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-charcoal">Quick links</h2>
        <ul class="mt-4 grid grid-cols-2 gap-x-4 gap-y-2 text-sm">
          {
            navItems.map(({ label, href }) => (
              <li>
                <a href={href} class="text-muted transition-colors hover:text-purple">
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="md:col-span-2 lg:col-span-1">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-charcoal">Service area</h2>
        <p class="mt-4 text-sm leading-relaxed text-muted">
          Serving Melbourne, Viera, Rockledge, Palm Bay, Titusville, Cocoa, Cocoa Beach, Satellite Beach,
          Cape Canaveral, Indialantic, Indian Harbour Beach, Merritt Island, West Melbourne, Suntree, and
          all of Brevard County, Florida.
        </p>
      </div>
    </div>

    <div class="mt-10 border-t border-charcoal/10 pt-8 text-center text-xs text-muted sm:text-left">
      <p>&copy; 2026 If Walls Could Talk LLC. All rights reserved.</p>
    </div>
  </div>
</footer>
