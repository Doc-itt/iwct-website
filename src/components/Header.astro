---
// Site header: logo, main nav (always visible from tablet up), phone CTA, and mobile menu on small screens.
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Services', href: '/services' },
  { label: 'Homeowner Guide', href: '/homeowner-guide' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];

const phone = '321-557-6959';
const phoneHref = 'tel:+13215576959';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

function isActive(href: string) {
  const normalized = href.replace(/\/$/, '') || '/';
  if (normalized === '/') return currentPath === '/';
  return currentPath === normalized || currentPath.startsWith(`${normalized}/`);
}

const linkClasses = (href: string) =>
  [
    'text-sm font-medium transition-colors whitespace-nowrap',
    isActive(href) ? 'text-purple' : 'text-muted hover:text-charcoal',
  ] as const;
---

<header class="sticky top-0 z-50 border-b border-charcoal/5 bg-cream/95 backdrop-blur-sm">
  <div class="page-container flex items-center justify-between gap-4 py-3 md:py-4">
    <a href="/" class="group shrink-0" aria-label="If Walls Could Talk — Home">
      <div class="flex items-center gap-3">
        <img
          src="/logotransparent.png"
          alt="If Walls Could Talk logo"
          width={48}
          height={48}
          class="h-10 w-10 object-contain sm:h-12 sm:w-12"
        />
        <span class="font-display text-lg font-semibold tracking-tight text-charcoal sm:text-xl">
          If Walls Could Talk
        </span>
      </div>
      <span class="watercolor-bar mt-1.5 block w-full max-w-[16rem] rounded-full" aria-hidden="true"></span>
    </a>

    <nav class="hidden min-w-0 flex-1 justify-center px-2 xl:flex" aria-label="Main navigation">
      <ul class="flex flex-wrap items-center justify-center gap-x-5 gap-y-1 2xl:gap-x-8">
        {
          navItems.map(({ label, href }) => (
            <li>
              <a href={href} class:list={linkClasses(href)} aria-current={isActive(href) ? 'page' : undefined}>
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex shrink-0 items-center gap-3 sm:gap-4">
      <a
        href={phoneHref}
        class="text-sm font-semibold text-purple transition-colors hover:text-coral sm:text-base"
        aria-label={`Call ${phone}`}
      >
        {phone}
      </a>

      <button
        type="button"
        id="menu-toggle"
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg text-charcoal transition-colors hover:bg-charcoal/5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-purple md:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open navigation menu"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path id="menu-icon-open" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          <path id="menu-icon-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <nav
    class="page-container hidden border-t border-charcoal/5 py-2.5 md:block xl:hidden"
    aria-label="Main navigation"
  >
    <ul class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 md:gap-x-6">
      {
        navItems.map(({ label, href }) => (
          <li>
            <a href={href} class:list={linkClasses(href)} aria-current={isActive(href) ? 'page' : undefined}>
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <nav
    id="mobile-menu"
    class="hidden border-t border-charcoal/5 bg-cream md:hidden"
    aria-label="Mobile navigation"
  >
    <ul class="page-container flex flex-col gap-1 py-4">
      {
        navItems.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class:list={[
                'block rounded-lg px-3 py-2.5 text-base font-medium transition-colors',
                isActive(href)
                  ? 'bg-purple/10 text-purple'
                  : 'text-charcoal hover:bg-charcoal/5',
              ]}
              aria-current={isActive(href) ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Close navigation menu' : 'Open navigation menu');
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.setAttribute('aria-label', 'Open navigation menu');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });
</script>
