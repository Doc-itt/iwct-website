---
// Service category bar: image cards for the four main service areas, linking to detail pages.
const categories = [
  {
    title: 'Exterior Painting',
    teaser:
      'Full exterior painting with proper prep and durable coatings built for Florida’s sun, salt air, and storms.',
    href: '/services/exterior-painting-brevard-county',
    image: '/images/services/exterior-repaint.jpg',
    imageAlt: 'Freshly painted exterior of a Brevard County home',
  },
  {
    title: 'Interior Painting',
    teaser:
      'Professional interior painting with careful prep and finishes that hold up well in Florida’s humidity.',
    href: '/services/interior-painting-brevard-county',
    image: '/images/services/interior-repaint.jpg',
    imageAlt: 'Interior room repainting in a Florida home',
  },
  {
    title: 'Specialty Finishes & Woodwork',
    teaser:
      'Cabinet painting, wood refinishing, and specialty details without needing a full remodel.',
    href: '/services/cabinet-painting-brevard-county',
    image: '/images/services/specialty-finishes.jpg',
    imageAlt: 'Cabinet and wood finishing work in a kitchen or bath',
  },
  {
    title: 'Outdoor Living and Concrete Coatings',
    teaser:
      'Pool decks, patios, and concrete surfaces with slip-resistant coatings built for Florida sun, rain, and heavy use.',
    href: '/services/pool-deck-painting-slip-resistant-coatings-brevard-county',
    image: '/images/services/outdoor-living-pool-deck.jpg',
    imageAlt: 'Pool deck and outdoor living surface coating',
  },
];
---

<section aria-labelledby="home-services-heading" class="mx-auto max-w-6xl">
  <h2
    id="home-services-heading"
    class="font-display text-2xl font-semibold tracking-tight text-charcoal sm:text-3xl"
  >
    Our Services
  </h2>
  <ul class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
    {
      categories.map((category) => (
        <li>
          <a
            href={category.href}
            class="group flex h-full flex-col overflow-hidden rounded-xl border border-charcoal/10 bg-white/60 transition-colors hover:border-purple/30 hover:bg-white/80"
          >
            <div class="aspect-[4/3] overflow-hidden bg-charcoal/5">
              <img
                src={category.image}
                alt={category.imageAlt}
                width={800}
                height={600}
                class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                loading="lazy"
              />
            </div>
            <div class="flex flex-1 flex-col p-4 sm:p-5">
              <h3 class="font-display text-lg font-semibold text-charcoal transition-colors group-hover:text-purple sm:text-xl">
                {category.title}
              </h3>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{category.teaser}</p>
              <p class="mt-3 text-sm font-medium text-purple transition-colors group-hover:text-coral">
                Learn more →
              </p>
            </div>
          </a>
        </li>
      ))
    }
  </ul>
  <p class="mt-5 text-sm text-muted sm:text-base">
    <a href="/services" class="font-medium text-purple transition-colors hover:text-coral">
      View all services →
    </a>
  </p>
</section>
