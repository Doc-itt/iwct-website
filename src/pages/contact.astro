---
// Contact page with Netlify form and project inquiry sidebar.
import Layout from '../layouts/Layout.astro';

const title = 'Contact Brevard County Painters | If Walls Could Talk';
const description =
  'Request a free quote for your painting project in Brevard County, FL. Fast responses, clear timelines, and no-pressure service from a local owner-operated company.';

const phone = '(321) 557-6959';
const phoneHref = 'tel:+13215576959';
const email = 'iwctpaintingplus@gmail.com';
const emailHref = 'mailto:iwctpaintingplus@gmail.com';

const inputClass =
  'w-full rounded-lg border border-charcoal/15 bg-white/80 px-4 py-2.5 text-charcoal placeholder:text-muted/70 focus:border-purple focus:outline-none focus:ring-2 focus:ring-purple/20';
const labelClass = 'mb-1.5 block text-sm font-medium text-charcoal';

const whatHappensNext = [
  'We review your message and project details.',
  'We plan a time to talk through scope, timeline, and what to expect.',
  'You get clear next steps — no pressure and no obligation.',
];
---

<Layout {title} {description}>
  <main class="page-container py-12 sm:py-16">
    <div class="mx-auto max-w-6xl">
      <header class="max-w-3xl">
        <h1 class="font-display text-3xl font-semibold tracking-tight sm:text-4xl">
          Talk to Us About Your Project
        </h1>
        <p class="mt-4 text-base leading-relaxed text-muted sm:text-lg">
          Whether you're ready to move forward or just want honest guidance, we’re happy 
          to help you understand your options, timeline, and what to expect before any work begins.
        </p>
      </header>

      <div class="mt-10 grid gap-10 lg:grid-cols-3 lg:gap-12">
        <section class="lg:col-span-2">
          <form
            name="contact"
            method="POST"
            action="/thank-you"
            data-netlify="true"
            data-netlify-honeypot="bot-field"
            class="rounded-xl border border-charcoal/10 bg-white/60 p-6 sm:p-8"
          >
            <input type="hidden" name="form-name" value="contact" />

            <p class="hidden" aria-hidden="true">
              <label>
                Don't fill this out:
                <input name="bot-field" tabindex="-1" autocomplete="off" />
              </label>
            </p>

            <div class="grid gap-5 sm:grid-cols-2">
              <div>
                <label for="name" class={labelClass}>Name</label>
                <input type="text" id="name" name="name" class={inputClass} />
              </div>
              <div>
                <label for="zip" class={labelClass}>Zip Code</label>
                <input type="text" id="zip" name="zip" class={inputClass} inputmode="numeric" />
              </div>
              <div>
                <label for="phone" class={labelClass}>Phone</label>
                <input type="tel" id="phone" name="phone" class={inputClass} />
              </div>
              <div>
                <label for="email" class={labelClass}>Email</label>
                <input type="email" id="email" name="email" class={inputClass} />
              </div>
            </div>

            <div class="mt-5">
              <label for="project-type" class={labelClass}>Project Type</label>
              <select id="project-type" name="project-type" class={inputClass}>
                <option value="">Select a project type</option>
                <option value="Interior Painting">Interior Painting</option>
                <option value="Exterior Painting">Exterior Painting</option>
                <option value="Cabinet Painting">Cabinet Painting</option>
                <option value="Pool Deck Painting">Pool Deck Painting</option>
                <option value="Other">Other</option>
              </select>
            </div>

            <div id="project-type-other-wrap" class="mt-5 hidden">
              <label for="project-type-other" class={labelClass}>Please describe your project type</label>
              <input type="text" id="project-type-other" name="project-type-other" class={inputClass} />
            </div>

            <div class="mt-5">
              <label for="referral" class={labelClass}>How did you hear about us?</label>
              <select id="referral" name="referral" class={inputClass}>
                <option value="">Select one</option>
                <option value="Google Search">Google Search</option>
                <option value="Google Maps / Google Business">Google Maps / Google Business</option>
                <option value="Referral from a friend or neighbor">Referral from a friend or neighbor</option>
                <option value="Facebook">Facebook</option>
                <option value="Other">Other</option>
              </select>
            </div>

            <div id="referral-other-wrap" class="mt-5 hidden">
              <label for="referral-other" class={labelClass}>How did you hear about us?</label>
              <input type="text" id="referral-other" name="referral-other" class={inputClass} />
            </div>

            <div class="mt-5">
              <label for="message" class={labelClass}>Message</label>
              <textarea id="message" name="message" rows={5} class={inputClass}></textarea>
            </div>

            <button type="submit" class="btn-primary mt-6">Send Message</button>
          </form>
        </section>

        <aside class="space-y-6">
          <div class="rounded-xl border border-charcoal/10 bg-white/60 p-6">
            <h2 class="font-display text-xl font-semibold text-charcoal">Contact</h2>
            <ul class="mt-4 space-y-3 text-sm sm:text-base">
              <li>
                <span class="font-medium text-charcoal">Phone:</span>{' '}
                <a href={phoneHref} class="text-purple transition-colors hover:text-coral">{phone}</a>
              </li>
              <li>
                <span class="font-medium text-charcoal">Email:</span>{' '}
                <a href={emailHref} class="break-all text-purple transition-colors hover:text-coral">{email}</a>
              </li>
            </ul>
          </div>

          <div class="rounded-xl border border-charcoal/10 bg-white/60 p-6">
            <h2 class="font-display text-xl font-semibold text-charcoal">What happens next</h2>
            <ul class="mt-4 space-y-3">
              {
                whatHappensNext.map((step) => (
                  <li class="flex items-start gap-3 text-sm leading-relaxed text-muted sm:text-base">
                    <span class="mt-1.5 inline-block h-2 w-2 shrink-0 rounded-full bg-purple" aria-hidden="true"></span>
                    <span>{step}</span>
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="rounded-xl border border-charcoal/10 bg-charcoal/[0.03] p-6">
            <h2 class="font-display text-lg font-semibold text-charcoal">Service area</h2>
            <p class="mt-3 text-sm leading-relaxed text-muted">
              We serve homeowners throughout Brevard County and the Space Coast, including Melbourne, Palm Bay,
              Viera, Titusville, Merritt Island, Cocoa, and surrounding communities.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </main>

  <script>
    function toggleOther(selectId: string, wrapId: string) {
      const select = document.getElementById(selectId) as HTMLSelectElement | null;
      const wrap = document.getElementById(wrapId);
      if (!select || !wrap) return;

      const update = () => {
        const show = select.value === 'Other';
        wrap.classList.toggle('hidden', !show);
      };

      select.addEventListener('change', update);
      update();
    }

    toggleOther('project-type', 'project-type-other-wrap');
    toggleOther('referral', 'referral-other-wrap');
  </script>
</Layout>
