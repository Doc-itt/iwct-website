---
// Homepage for IWCT: core messaging, standards, FAQs, and structured data for search.
import Layout from '../layouts/Layout.astro';
import FaqSection from '../components/FaqSection.astro';
import ServiceCategoryBar from '../components/ServiceCategoryBar.astro';
import { googleReviewHref } from '../data/google-business';

const siteUrl = 'https://ifwallscouldtalkllc.com';

const title = 'Brevard County Painters | If Walls Could Talk';
const description =
  'Professional owner-operated painting services in Brevard County, FL. Vetted crews deliver quality interior, exterior, cabinet, and outdoor living results with proper preparation and clear communication.';

const includedItems = [
  'Vetted local crews',
  'Clear scope of work before the project begins',
  'Defined timelines and expectations',
  'Regular communication and progress updates',
  'Thorough surface preparation',
  'Materials selected for Florida’s heat, humidity, and coastal conditions',
  'Work completed according to agreed upon project standards',
  'Complete paint record after the job, including all products and colors for future maintenance',
];

const goalItems = [
  'Clear expectations',
  'Proper preparation',
  'Consistent communication',
  'A finished result that holds up in Florida’s climate',
];

const reviews = [
  {
    name: 'Sharon Evans',
    date: '2026-05',
    dateLabel: 'May 2026',
    googleShareUrl: 'https://maps.app.goo.gl/59gsA4Jy71Xs3zqJA',
    quote:
      'If Walls Could Talk is the only painting company I would recommend in Brevard County. Heather has incredibly high standards, communicates well, and truly cares about the quality of the finished work. The attention to detail really stood out...',
  },
  {
    name: 'George Pecovic',
    date: '2023-06-20',
    dateLabel: 'June 2023',
    googleShareUrl: 'https://maps.app.goo.gl/k8nh8toXhjhVMmQR9',
    quote:
      'We have used If Walls Could Talk on several projects... They did a complete painting of the unit and also refurbished the kitchen cabinets. Her color recommendations were excellent... everything was meticulously cleaned and ready to be rented giving us absolute satisfaction.',
  },
  {
    name: 'Cohen Mahon',
    date: '2021-03-08',
    dateLabel: 'March 2021',
    googleShareUrl: 'https://maps.app.goo.gl/CuuKMFj2iWB136UVA',
    quote:
      'Great services at a reasonable price, very detail oriented. She was really respectful and polite. Would definitely recommend.',
  },
];

const faqs = [
  {
    question: 'What areas do you serve?',
    answer:
      "We serve all of Brevard County, Florida, including Melbourne, Palm Bay, Viera, Rockledge, Titusville, Cocoa, Cocoa Beach, Satellite Beach, Cape Canaveral, Merritt Island, Indialantic, and Indian Harbour Beach. If you're anywhere on the Space Coast, we can help with your project.",
  },
  {
    question: 'Do painters in Florida need to be licensed?',
    answer:
      'No. Florida does not require a painting license. This means hiring the right contractor comes down to experience, insurance, and clearly defined standards — not a license number.',
    footerLinks: [
      {
        label: 'Hiring a Painter in Brevard County, FL',
        href: '/homeowner-guide/hiring-a-painter-brevard-county',
      },
      {
        label: 'Florida Removed the Painting License Requirement',
        href: '/blog/florida-painting-contractor-license-changes-brevard',
      },
    ],
  },
  {
    question: 'What types of projects do you handle?',
    answer:
      'We handle interior painting, exterior painting, cabinet painting, pool deck painting, and minor repair work across Brevard County. Every project follows the same standards for preparation, materials, and communication.',
    footerLinks: [{ label: 'Painting Services', href: '/services' }],
  },
  {
    question: 'How do I get an estimate?',
    answerHtml: true,
    answer:
      'Call <a href="tel:+13215576959" class="text-purple transition-colors hover:text-coral">321-557-6959</a> or through the <a href="/contact" class="text-purple transition-colors hover:text-coral">contact page</a>. We’ll review your project, timeline, and scope with no pressure and no obligation.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer.replace(/<[^>]+>/g, ''),
    },
  })),
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${siteUrl}/#service`,
  name: 'Residential Painting Services in Brevard County',
  description:
    'Interior painting, exterior painting, cabinet painting, pool deck painting, and minor repair services with clear scope, prep standards, and paint records.',
  serviceType: 'Residential painting services',
  provider: { '@id': `${siteUrl}/#localbusiness` },
  areaServed: {
    '@type': 'AdministrativeArea',
    name: 'Brevard County, Florida',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Painting Services',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Interior Painting' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Exterior Painting' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Cabinet Painting' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Pool Deck Painting' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Minor Repair Work' } },
    ],
  },
};

const listClass =
  'space-y-3 rounded-xl border border-charcoal/10 bg-white/60 p-5 sm:p-6';
const listItemClass = 'flex items-start gap-3 text-sm sm:text-base';
const bulletClass = 'mt-1 inline-block h-2.5 w-2.5 shrink-0 rounded-full bg-purple';
---

<Layout {title} {description} ogImage="/logotransparent.png">
  <div class="page-container space-y-14 py-12 sm:py-16">
    <article class="mx-auto max-w-4xl text-base leading-relaxed text-charcoal sm:text-lg">
      <header class="space-y-6">
        <h1 class="font-display text-3xl font-semibold tracking-tight sm:text-4xl lg:text-5xl">
          Painting Services for Brevard County — Built on Clear Standards and Accountability
        </h1>
        <p>
          If Walls Could Talk is owner-operated and works with vetted local crews. Every project, large or small,
          follows clear standards for preparation, materials, communication, and cleanup. This means you always know
          what to expect and exactly how the work is being handled.
        </p>
        <div class="flex flex-col items-center gap-4 pt-2 sm:gap-5 sm:pt-4">
          <a href="/contact" class="btn-primary text-center">
            Talk About Your Project or Get an Estimate
          </a>
          <a
            href="/homeowner-guide"
            class="text-sm font-medium text-purple underline-offset-4 transition-colors hover:text-coral hover:underline sm:text-base"
          >
            What to Know Before Hiring a Painter
          </a>
        </div>
      </header>
    </article>

    <ServiceCategoryBar />

    <article class="mx-auto max-w-4xl space-y-14 text-base leading-relaxed text-charcoal sm:text-lg">
      <div class="watercolor-divider" aria-hidden="true"></div>

      <section class="space-y-5" aria-labelledby="our-process-heading">
        <h2 id="our-process-heading" class="font-display text-2xl font-semibold sm:text-3xl">Our Process</h2>
        <p>
          If Walls Could Talk (IWCT) gives homeowners a more accountable and transparent painting experience.
        </p>
        <p>
          Florida does not require a painting license, so quality can vary significantly between contractors. IWCT
          exists to reduce that uncertainty by setting clear standards and working only with vetted crews who follow
          them consistently.
        </p>
        <p>
          We help define the scope and expectations for each job and stay involved to make sure the work is completed
          correctly and meets the agreed upon standards.
        </p>
        <p>The goals are simple:</p>
        <ul class={listClass}>
          {goalItems.map((item) => (
            <li class={listItemClass}>
              <span class={bulletClass} aria-hidden="true"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </section>

      <div class="watercolor-divider" aria-hidden="true"></div>

      <section class="space-y-5" aria-labelledby="job-includes-heading">
        <h2 id="job-includes-heading" class="font-display text-2xl font-semibold sm:text-3xl">What Every Job Includes</h2>
        <ul class={listClass}>
          {includedItems.map((item) => (
            <li class={listItemClass}>
              <span class={bulletClass} aria-hidden="true"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </section>

      <div class="watercolor-divider" aria-hidden="true"></div>

      <section class="space-y-8" aria-labelledby="reviews-heading">
        <div class="space-y-2">
          <h2 id="reviews-heading" class="font-display text-2xl font-semibold sm:text-3xl">
            What Homeowners Say
          </h2>
          <p class="text-sm text-muted sm:text-base">From Google reviews</p>
        </div>
        <div class="grid gap-6 md:grid-cols-3" role="list">
          {reviews.map((review) => (
            <figure
              class="flex h-full flex-col rounded-xl border border-charcoal/10 bg-white/60 p-5 sm:p-6"
              role="listitem"
            >
              <div class="mb-4 text-purple/80" aria-label="5 out of 5 stars">
                <span class="text-sm tracking-wide" aria-hidden="true">★★★★★</span>
              </div>
              <blockquote class="flex-1 text-sm leading-relaxed text-charcoal sm:text-base">
                <p>“{review.quote}”</p>
              </blockquote>
              <figcaption class="mt-5 border-t border-charcoal/10 pt-4 text-sm text-muted">
                <div>
                  <span class="font-medium text-charcoal">{review.name}</span>
                  <span class="mx-1.5" aria-hidden="true">·</span>
                  <time datetime={review.date}>{review.dateLabel}</time>
                </div>
                <a
                  href={googleReviewHref(review)}
                  class="mt-2 inline-block text-xs text-purple transition-colors hover:text-coral"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Read review on Google
                  <span class="sr-only"> — {review.name}</span>
                </a>
              </figcaption>
            </figure>
          ))}
        </div>
      </section>

      <FaqSection items={faqs} />
    </article>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
</Layout>
