---
// This page presents IWCT's core home messaging, standards, and homeowner FAQs.
import Layout from '../layouts/Layout.astro';

const title = 'Brevard County Painting Services | IWCT';
const description =
  'Owner-operated Brevard County painting services with vetted crews, clear standards, and Florida-ready prep. Transparent communication across the Space Coast.';

const includedItems = [
  'Vetted local crews',
  'Clear scope of work before the project begins',
  'Defined timelines and expectations',
  'Regular communication and progress updates',
  'Thorough surface preparation',
  'Materials selected for Florida’s heat, humidity, and coastal conditions',
  'Work completed according to agreed project standards',
  'Complete paint record after the job, including all products and colors for future maintenance',
];

const faqs = [
  {
    question: 'What areas do you serve?',
    answer:
      "We serve all of Brevard County, Florida, including Melbourne, Palm Bay, Viera, Rockledge, Titusville, Cocoa, Cocoa Beach, Satellite Beach, Cape Canaveral, Merritt Island, Indialantic, and Indian Harbour Beach. If you're anywhere on the Space Coast, we can help with your project.",
  },
  {
    question: 'Do painters in Florida need to be licensed?',
    answer:
      'No. Florida does not require a painting license. This means hiring the right contractor comes down to experience, insurance, and clearly defined standards — not a license number.',
  },
  {
    question: 'How does If Walls Could Talk work?',
    answer:
      'If Walls Could Talk is owner-operated. Heather sets the standards for each project and works with vetted local crews who complete the work according to those expectations. The focus is clear communication, proper preparation, and consistent quality from start to finish.',
  },
  {
    question: 'What types of projects do you handle?',
    answer:
      'We handle interior painting, exterior painting, cabinet painting, pool deck painting, and minor repair work across Brevard County. Every project follows the same standards for preparation, materials, and communication.',
  },
  {
    question: 'How do I get an estimate?',
    answer:
      'Call 321-557-6959 or reach out through the contact page. We’ll review your project, timeline, and scope with no pressure and no obligation.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'If Walls Could Talk LLC',
  url: 'https://ifwallscouldtalkllc.com/',
  telephone: '+1-321-557-6959',
  email: 'iwctpaintingplus@gmail.com',
  areaServed: ['Brevard County, Florida', 'Space Coast, Florida'],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Melbourne',
    addressRegion: 'FL',
    addressCountry: 'US',
  },
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Residential painting services',
  provider: {
    '@type': 'LocalBusiness',
    name: 'If Walls Could Talk LLC',
  },
  areaServed: {
    '@type': 'AdministrativeArea',
    name: 'Brevard County, Florida',
  },
};
---

<Layout {title} {description}>
  <main class="page-container py-12 sm:py-16">
    <article class="mx-auto max-w-4xl space-y-14 text-base leading-relaxed text-charcoal sm:text-lg">
      <section class="space-y-6">
        <h1 class="font-display text-3xl font-semibold tracking-tight sm:text-4xl lg:text-5xl">
          Painting Services for Brevard County Homeowners — Built on Clear Standards and Accountability
        </h1>
        <p>
          If Walls Could Talk is owner-operated and works with vetted local crews. Every project follows clear
          standards for preparation, materials, communication, and cleanup — so you always know what to expect and how
          the work is being handled.
        </p>
        <a href="/contact" class="btn-primary mt-6 inline-flex text-center sm:mt-8">
          Talk About Your Project or Get an Estimate
        </a>
      </section>

      <div class="watercolor-divider" aria-hidden="true"></div>

      <section class="space-y-5">
        <h2 class="font-display text-2xl font-semibold sm:text-3xl">How This Works</h2>
        <p>If Walls Could Talk is built to give homeowners a more accountable and transparent painting experience.</p>
        <p>
          Florida does not require a painting license, which means quality can vary widely from contractor to
          contractor. IWCT exists to reduce that uncertainty by setting clear expectations and working with crews who
          follow them.
        </p>
        <p>
          We work with a small group of vetted local crews on a project-by-project basis. I help define the scope and
          expectations for each job and stay involved to make sure the work is completed correctly and meets the
          agreed standards.
        </p>
        <p>
          The goal is simple: clear expectations, proper preparation, consistent communication, and a finished result
          that holds up in Florida’s climate.
        </p>
      </section>

      <div class="watercolor-divider" aria-hidden="true"></div>

      <section class="space-y-5">
        <h2 class="font-display text-2xl font-semibold sm:text-3xl">What Every Job Includes</h2>
        <ul class="space-y-3 rounded-xl border border-charcoal/10 bg-white/60 p-5 sm:p-6">
          {includedItems.map((item) => (
            <li class="flex items-start gap-3 text-sm sm:text-base">
              <span class="mt-1 inline-block h-2.5 w-2.5 shrink-0 rounded-full bg-purple"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </section>

      <section class="space-y-6 border-t border-charcoal/10 pt-10">
        <h2 class="font-display text-2xl font-semibold sm:text-3xl">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqs.map((faq) => (
            <details class="rounded-lg border border-charcoal/10 bg-white/70 p-4">
              <summary class="cursor-pointer list-none pr-6 font-semibold text-charcoal [&::-webkit-details-marker]:hidden">
                {faq.question}
                <span class="float-right text-purple">+</span>
              </summary>
              <p class="mt-3 text-muted">{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>
    </article>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
</Layout>
