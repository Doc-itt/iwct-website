---
// Thank-you page shown after contact form submission.
import Layout from '../layouts/Layout.astro';

const title = 'Thank You | If Walls Could Talk';
const description =
  'Thank you for contacting If Walls Could Talk. We will be in touch soon about your Brevard County painting project.';

const phone = '(321) 557-6959';
const phoneHref = 'tel:+13215576959';
const email = 'iwctpaintingplus@gmail.com';
const emailHref = 'mailto:iwctpaintingplus@gmail.com';
---

<Layout {title} {description}>
  <main class="page-container py-12 sm:py-20">
    <article class="mx-auto max-w-3xl text-center">
      <h1 class="font-display text-3xl font-semibold tracking-tight sm:text-4xl">Thank You</h1>
      <p class="mt-4 text-base leading-relaxed text-muted sm:text-lg">
        Your message is on its way. We appreciate you reaching out and will follow up soon to talk through your
        project, timeline, and what to expect.
      </p>

      <div class="mt-8 rounded-xl border border-charcoal/10 bg-white/60 p-6 text-left sm:p-8">
        <p class="text-sm font-medium text-charcoal sm:text-base">Need to reach us directly?</p>
        <ul class="mt-3 space-y-2 text-sm sm:text-base">
          <li>
            <span class="text-muted">Phone:</span>{' '}
            <a href={phoneHref} class="font-medium text-purple transition-colors hover:text-coral">{phone}</a>
          </li>
          <li>
            <span class="text-muted">Email:</span>{' '}
            <a href={emailHref} class="font-medium text-purple transition-colors hover:text-coral">{email}</a>
          </li>
        </ul>
      </div>

      <div class="mt-8 rounded-xl border border-purple/20 bg-purple/5 p-6 text-left sm:p-8">
        <h2 class="font-display text-xl font-semibold text-charcoal">Before you hire any painter</h2>
        <p class="mt-3 text-sm leading-relaxed text-muted sm:text-base">
          Florida does not require a painting license, so quality and accountability vary widely. Our homeowner
          guide walks you through what to ask, what prep should include, and how to protect your investment before
          you hire anyone.
        </p>
        <a
          href="/homeowner-guide"
          class="mt-4 inline-block text-sm font-semibold text-purple transition-colors hover:text-coral"
        >
          Read the Homeowner Guide →
        </a>
      </div>

      <a href="/" class="btn-primary mt-10">Back to Home</a>
    </article>
  </main>
</Layout>
